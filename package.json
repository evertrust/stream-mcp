{
  "name": "@evertrust/stream-mcp",
  "version": "0.1.0",
  "description": "MCP server for Evertrust Stream 2.1 (PKI: CA, VA/OCSP, TSA, SSH)",
  "license": "Apache-2.0",
  "type": "module",
  "bin": { "stream-mcp": "dist/index.js" },
  "files": ["dist"],
  "engines": { "node": ">=24.10" },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts --reporter=verbose",
    "test:scenarios": "vitest run --config vitest.config.llm.ts --reporter=verbose",
    "test:llm": "vitest run --config vitest.config.llm.ts --reporter=verbose",
    "test:llm:live": "vitest run --config vitest.config.llm-live.ts --reporter=verbose"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "undici": "^8.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.145",
    "@eslint/js": "^9.18.0",
    "@types/node": "^24.10.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.2"
  }
}
