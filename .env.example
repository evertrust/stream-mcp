# Stream MCP Server Configuration
# Copy to .env.local and adjust for your environment.

# === Required ===
STREAM_URL=https://stream.example.com

# === Authentication (auto-detected from which variables are set) ===
# Priority: mTLS (client cert) > local account (API headers)

# Option 1: Local account (username/password via Stream API headers)
STREAM_API_ID=<your-username>
STREAM_API_KEY=<your-password>
# Identity provider name (the local provider is usually "local").
STREAM_API_IDPROV=local

# Option 2: mTLS with PEM files
# STREAM_CLIENT_CERT=/path/to/client.crt
# STREAM_CLIENT_KEY=/path/to/client.key
# STREAM_CLIENT_KEY_PASSWORD=<optional-key-password>

# Option 3: mTLS with PKCS#12 / PFX
# STREAM_CLIENT_PFX=/path/to/client.p12
# STREAM_CLIENT_PFX_PASSWORD=<optional-pfx-password>

# === Optional - TLS and timeouts ===
STREAM_VERIFY_SSL=true
STREAM_TIMEOUT=30
STREAM_EXPORT_TIMEOUT=120

# === Optional - security hardening ===
# Allow REST notification triggers to target loopback/link-local/private hosts.
# Blocked by default (SSRF protection); set to true only for trusted internal webhooks.
# STREAM_ALLOW_INTERNAL_URLS=false
# Restrict which PKCS#11 library paths the HSM tools may load (comma-separated
# absolute paths). When unset, the caller-supplied path is forwarded to Stream.
# STREAM_HSM_LIBRARY_ALLOWLIST=/usr/lib/softhsm/libsofthsm2.so

# === Optional - logging and version compatibility ===
STREAM_LOG_LEVEL=INFO
# STREAM_TESTED_VERSIONS=2.1
# STREAM_WARN_VERSIONS=2.0,2.2

# === Development / testing only (never read by the server itself) ===
# STREAM_E2E_URL=https://stream-21.qa.evertrust.io
# STREAM_E2E_API_ID=<your-e2e-username>
# STREAM_E2E_API_KEY=<your-e2e-password>
